// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/java
{
	"name": "ref-IDP-Server",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/java:1-21-bullseye",
	"features": {
		//Use local socket via "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers-contrib/features/act:1": {},
		"ghcr.io/devcontainers/features/java:1": {
			"installGradle": true,
			"installMaven": true,
			"installGroovy": true,
			"version": "21",
			"jdkDistro": "tem",
			"gradleVersion": "7.5.1",
			"mavenVersion": "latest",
			"antVersion": "latest",
			"groovyVersion": "latest"
		},
		"ghcr.io/devcontainers-contrib/features/tmux-apt-get:1": {},
        "ghcr.io/devcontainers/features/sshd:1": {
			"START_SSHD": "true",
      "NEW_PASSWORD": "qwertz."
		}
	},
	"remoteEnv": {
		"GH_TOKEN": "${localEnv:GH_TOKEN:localEnv:GITHUB_TOKEN}"
	},
	"runArgs": [
		"--hostname",
		"idp-devcontainer"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"DavidAnson.vscode-markdownlint",
				"GitHub.copilot",
				"MS-CEINTL.vscode-language-pack-de",
				"ms-azuretools.vscode-docker",
				"ms-vscode-remote.vscode-remote-extensionpack",
				"fwcd.kotlin",
				"formulahendry.code-runner",
				"GitHub.copilot-chat",
				"vscjava.vscode-java-pack",
				"vscjava.vscode-gradle",
				"vscjava.vscode-java-test",
				"github.vscode-github-actions"
			],
			"settings": {
				"files.autoSave": "afterDelay",
				"editor.smoothScrolling": true,
				"terminal.integrated.lineHeight": 1.5,
				"editor.fontLigatures": true,
				"editor.lineHeight": 1.5,
				"editor.minimap.enabled": false,
				"editor.tabSize": 2,
				"editor.semanticTokenColorCustomizations": {
					"enabled": true
				},
				"editor.semanticHighlighting.enabled": true,
				"files.eol": "\n",
				"extensions.ignoreRecommendations": true,
				"task.problemMatchers.neverPrompt": {
					"shell": true
				}
			}
		}
	},
    "appPort": [
		// 2222 Expose SSH port for tools that need it (e.g. JetBrains)
		"127.0.0.1:2222:2222", "127.0.0.1:3001:3001","127.0.0.1:8571:127.0.0.1:8571"
	],
  "portsAttributes": {
    "3001": {
      "label": "ERPService"
    },
	"8571":{
		"label": "IDP-Server"
	}
  }
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
		// "forwardPorts": [],
			// Use 'postCreateCommand' to run commands after the container is created.
		// Configure tool-specific properties.
		// "customizations": {},
		// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
		// "remoteUser": "root"
	}
